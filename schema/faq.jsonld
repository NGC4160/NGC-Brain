{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What areas does Neighborhood Golf Carts serve?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Covington, Madisonville, Mandeville, Hammond, New Orleans, Kenner, Metairie, Slidell, and surrounding Southeast Louisiana. Northshore customers within 40 miles of Covington receive free pickup and delivery. Southshore customers use flat-rate transport."
      }
    },
    {
      "@type": "Question",
      "name": "What services does Neighborhood Golf Carts offer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Golf cart repair, maintenance, and accessories including battery replacement, tire and brake service, electrical diagnostics, motor troubleshooting, lithium conversions, and fleet maintenance — with pickup and delivery."
      }
    },
    {
      "@type": "Question",
      "name": "How do I book service with Neighborhood Golf Carts?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Call (985) 402-1206 or use the contact form at ngcgolfcarts.com/contact-us. NGC schedules pickup, confirms by text and email, repairs at the Covington shop, and returns your cart ready to ride."
      }
    },
    {
      "@type": "Question",
      "name": "Is pickup free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes for Northshore customers within 40 miles of the Covington shop. Southshore customers in New Orleans, Kenner, and Metairie pay a flat-rate transport fee."
      }
    },
    {
      "@type": "Question",
      "name": "What golf cart brands do you service?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Club Car, EZGO, Yamaha, and most major brands. NGC services both gas and electric golf carts."
      }
    },
    {
      "@type": "Question",
      "name": "How long do lithium conversions take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most LiFePO4 conversions are completed in 3–5 business days in shop, or about one week total including pickup and delivery."
      }
    }
  ]
}
