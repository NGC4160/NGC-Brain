# Copy to .env — never commit .env

# Housecall Pro API (MAX/XL plan required)
# Get your key: Housecall Pro → App Store → API
HCP_API_KEY=

# Optional HCP overrides
# HCP_BASE_URL=https://api.housecallpro.com
# HCP_COMPANY_ID=

# QuickBooks Online (Intuit Developer app)
# Bookkeeper: Griffin & Furman, LLC — QBO remains accounting system of record
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3001/api/qbo/callback
QBO_ENVIRONMENT=production
# QBO_REALM_ID=

# Local DMS database (SQLite)
# DATABASE_PATH=data/ngc.db

# API proxy port (local dev)
# PORT=3001

# Frontend API base (leave empty for same-origin in dev)
# VITE_HCP_API_URL=http://localhost:3001
