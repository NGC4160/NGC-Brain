# Copy to .env and fill in — never commit .env

# Housecall Pro (MAX/XL plan required for API)
# HCP_API_KEY=

# Intuit QuickBooks OAuth (API sync + MCP)
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_REALM_ID=
# QBO_REFRESH_TOKEN=
# QBO_ENVIRONMENT=production

# Command Center login (also set as GitHub Actions secret)
# NGC_COMMAND_CENTER_PASSWORD=

# Optional: Zapier webhook URLs for no-code automations
# ZAPIER_HCP_JOB_COMPLETED=
# ZAPIER_WEEKLY_REVIEW_REMINDER=
